{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gif-editor",
  "version": "0.1.0",
  "identifier": "dev.quinnjr.gif-editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "GIF Editor",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$TEMP/**", "$HOME/**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["gif"],
        "mimeType": "image/gif",
        "description": "GIF image"
      },
      {
        "ext": ["mp4"],
        "mimeType": "video/mp4",
        "description": "MP4 video"
      },
      {
        "ext": ["webm"],
        "mimeType": "video/webm",
        "description": "WebM video"
      },
      {
        "ext": ["png"],
        "mimeType": "image/png",
        "description": "PNG image"
      },
      {
        "ext": ["jpg", "jpeg"],
        "mimeType": "image/jpeg",
        "description": "JPEG image"
      },
      {
        "ext": ["webp"],
        "mimeType": "image/webp",
        "description": "WebP image"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
